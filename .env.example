# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# JWT
JWT_SECRET=your_jwt_secret_key_here

# Cloudinary Configuration
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_upload_preset

# Server Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend base URL used to build password-reset links in emails
CLIENT_URL=http://localhost:5173

# SMTP email (password reset). Leave blank in dev to log reset links to the server console.
# Gmail example: host=smtp.gmail.com, port=587, user=your@gmail.com, pass=16-char app password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Titan HR <your@gmail.com>
